{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "build/web",
  "installCommand": "echo 'Flutter installed in buildCommand'",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://novora-api-wf1w.onrender.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://novora-api-wf1w.onrender.com/auth/:path*"
    },
    {
      "source": "/actuator/:path*",
      "destination": "https://novora-api-wf1w.onrender.com/actuator/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
