# API base URL for Spring Boot backend (override per environment).
# Flutter web: the app tab is often http://localhost:* while this uses 127.0.0.1 — different sites for
# cookies, which breaks session+CSRF (403). ApiClient auto-uses the tab hostname for loopback APIs.
API_BASE_URL=http://127.0.0.1:8080
# If the web app is opened via LAN IP (e.g. http://192.168.x.x:port), add that pattern to the
# backend: app.cors.additional-origin-patterns=http://192.168.x.x:*
